# QRMES v3.0 钉钉 bot 主配置模板
DINGTALK_BOT_MODE=stream
DINGTALK_BOT_HOST=0.0.0.0
DINGTALK_BOT_PORT=8899
DINGTALK_BOT_LOG_LEVEL=INFO

# 钉钉 stream/http 凭据（二选一即可，推荐直接沿用 CLIENT_*）
DINGTALK_BOT_APP_KEY=
DINGTALK_BOT_APP_SECRET=
DINGTALK_BOT_CLIENT_ID=
DINGTALK_BOT_CLIENT_SECRET=
DINGTALK_BOT_ROBOT_CODE=
DINGTALK_BOT_CALLBACK_TOKEN=
DINGTALK_BOT_CALLBACK_AES_KEY=
DINGTALK_BOT_CALLBACK_RECEIVE_ID=
DINGTALK_BOT_API_BASE_URL=https://api.dingtalk.com

# MES / 数据库 / 文档配置（可直接沿用旧值）
MES_BOT_API_BASE=http://127.0.0.1:8891
DINGTALK_BOT_PROJECT_CONFIG_DB_PATH=/volume2/MES/QRMES/projects/project_configs.db
DINGTALK_BOT_WEB_USERS_DB_PATH=/volume2/MES/QRMES/web_users.db
DINGTALK_BOT_UNIFIED_DB_PATH=/volume2/MES/QRMES/unified.db
DINGTALK_BOT_USER_ALIASES_PATH=/volume2/qrmes-v3.0/qrmes-dingtalk-bot/dingtalk_mes_bot/mes_user_aliases.json
DINGTALK_BOT_DOC_WORKSPACE_ID=
DINGTALK_BOT_DOC_PARENT_NODE_ID=
DINGTALK_BOT_DOC_OPERATOR_ID=
DINGTALK_BOT_DOC_STATE_PATH=/volume2/qrmes-v3.0/qrmes-dingtalk-bot/dingtalk_mes_bot/cache/daily_docs.json

# 文本/视觉模型链路
DINGTALK_BOT_LLM_BASE_URL=http://172.16.20.201:1234/v1
DINGTALK_BOT_LLM_API_KEY=
DINGTALK_BOT_LLM_TIMEOUT=20
DINGTALK_BOT_TEXT_MODEL=qwen3.5-35b-a3b
DINGTALK_BOT_VISION_MODEL=qwen/qwen3-vl-30b

# Hermes 文本链路（新版新增）
DINGTALK_BOT_HERMES_BASE_URL=http://172.16.20.201:8787
DINGTALK_BOT_HERMES_WORKSPACE=/Volumes/172.16.30.10/volume2/qrmes-v3.0/qrmes-dingtalk-bot
DINGTALK_BOT_HERMES_MODEL=gpt-5.5
