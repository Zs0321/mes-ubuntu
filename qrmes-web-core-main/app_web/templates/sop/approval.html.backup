{% extends "base.html" %}

{% block title %}审批流程 - MES系统{% endblock %}

{% block head %}
<style>
/* SOP全屏页面样式 - 强制全屏显示 */
.sop-page {
    display: grid !important;
    gap: 1.5rem !important;
    color: var(--text-primary) !important;
    width: 100vw !important;
    max-width: 100vw !important;
    margin: 0 !important;
    padding: 0 !important;
    box-sizing: border-box !important;
}

/* 彻底覆盖.container的所有限制 */
body .container .sop-page,
html .container .sop-page,
.container .sop-page,
.sop-page {
    width: 100vw !important;
    max-width: 100vw !important;
    margin: 0 !important;
    padding: 0 1.5rem !important;
    box-sizing: border-box !important;
}

/* 覆盖.container本身 */
body:has(.sop-page) .container,
.container:has(.sop-page) {
    max-width: 100vw !important;
    width: 100vw !important;
    margin: 0 !important;
    padding: 0 !important;
}

.approval-container {
    max-width: 100% !important;
    margin: 0 !important;
    padding: 0 1.5rem !important;
}

.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
}

.page-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.tabs {
    display: flex;
    gap: 0.5rem;
    background: var(--surface);
    padding: 0.375rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    margin-bottom: 2rem;
}

.tab-btn {
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: all var(--transition-fast);
}

.tab-btn:hover {
    color: var(--text-primary);
}

.tab-btn.active {
    background: var(--primary);
    color: #0a0a0a;
}

.approval-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.approval-item {
    background: var(--surface-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-fast);
}

.approval-item:hover {
    border-color: var(--border-strong);
}

.approval-item-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
}

.approval-item-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.approval-item-title-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.approval-item-file-number {
    font-size: 1rem;
    font-weight: 600;
    color: var(--primary);
}

.approval-item-title {
    font-size: 1rem;
    color: var(--text-primary);
}

.approval-item-meta {
    display: flex;
    gap: 1.5rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
}

.approval-item-status {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
}

.current-step {
    font-size: 0.75rem;
    color: var(--text-muted);
}

.approval-item-body {
    padding: 1.5rem;
}

.approval-flow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
}

.flow-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    min-width: 80px;
}

.flow-step-icon {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    background: var(--surface);
    border: 2px solid var(--border);
    color: var(--text-muted);
}

.flow-step.completed .flow-step-icon {
    background: rgba(34, 197, 94, 0.16);
    border-color: #22c55e;
    color: #22c55e;
}

.flow-step.current .flow-step-icon {
    background: rgba(56, 189, 248, 0.16);
    border-color: var(--primary);
    color: var(--primary);
}

.flow-step-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-align: center;
}

.flow-connector {
    flex: 1;
    height: 2px;
    background: var(--border);
    min-width: 20px;
}

.flow-connector.completed {
    background: #22c55e;
}

.approval-actions {
    display: flex;
    gap: 0.75rem;
}

.action-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-fast);
    border: none;
}

.action-btn.primary {
    background: var(--primary);
    color: #0a0a0a;
}

.action-btn.success {
    background: #22c55e;
    color: #0a0a0a;
}

.action-btn.danger {
    background: rgba(239, 68, 68, 0.16);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.32);
}

.action-btn.secondary {
    background: var(--surface);
    color: var(--text-primary);
    border: 1px solid var(--border);
}

.approval-comment {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
}

.comment-input {
    width: 100%;
    padding: 0.75rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: 0.875rem;
    resize: vertical;
    min-height: 80px;
}

.comment-input:focus {
    outline: none;
    border-color: var(--primary);
}

.history-section {
    background: var(--surface-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    margin-top: 2rem;
}

.history-header {
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
}

.history-list {
    padding: 1rem;
    max-height: 400px;
    overflow-y: auto;
}

.history-item {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    border-radius: var(--radius-md);
    transition: background var(--transition-fast);
}

.history-item:hover {
    background: var(--surface);
}

.history-time {
    min-width: 140px;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
}

.history-content {
    flex: 1;
}

.history-title {
    font-size: 0.875rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
}

.history-meta {
    font-size: 0.75rem;
    color: var(--text-secondary);
}

.history-action {
    display: inline-flex;
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 500;
    margin-left: 0.5rem;
}

.history-action.approve {
    background: rgba(34, 197, 94, 0.16);
    color: #22c55e;
}

.history-action.reject {
    background: rgba(239, 68, 68, 0.16);
    color: #ef4444;
}

.history-action.return {
    background: rgba(251, 191, 36, 0.16);
    color: #fbbf24;
}

.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-fast);
    border: none;
    text-decoration: none;
}

.btn-secondary {
    background: var(--surface);
    color: var(--text-primary);
    border: 1px solid var(--border);
}

.btn-secondary:hover {
    border-color: var(--border-strong);
}

.empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-secondary);
}

.empty-state-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.5;
}

.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(5, 8, 18, 0.9);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
}

.modal-overlay.active {
    display: flex;
}

.modal {
    background: var(--surface-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    width: 90%;
    max-width: 500px;
    max-height: 90vh;
    overflow-y: auto;
}

.modal-header {
    padding: 1.5rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.modal-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
}

.modal-close {
    color: var(--text-muted);
    cursor: pointer;
    font-size: 1.25rem;
}

.modal-body {
    padding: 1.5rem;
}

.modal-footer {
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
}
</style>
{% endblock %}

{% block content %}
<div class="sop-page">
<div class="approval-container">
    <div class="page-header">
        <h1 class="page-title">
            <span>📋</span>
            审批流程
        </h1>
        <a href="{{ url_for('sop.sop_home') }}" class="btn btn-secondary">
            ← 返回首页
        </a>
    </div>
    
    <!-- 标签页切换 -->
    <div class="tabs">
        <button class="tab-btn active" onclick="switchTab('pending')">
            ⏳ 待我审批 <span class="badge" id="pending-count">0</span>
        </button>
        <button class="tab-btn" onclick="switchTab('submitted')">
            📤 我提交的
        </button>
        <button class="tab-btn" onclick="switchTab('approved')">
            ✅ 已审批的
        </button>
        <button class="tab-btn" onclick="switchTab('all')">
            📋 全部
        </button>
    </div>
    
    <!-- 审批列表 -->
    <div class="approval-list" id="approval-list">
        <!-- 动态生成 -->
    </div>
    
    <!-- 空状态 -->
    <div class="empty-state" id="empty-state" style="display: none;">
        <div class="empty-state-icon">🎉</div>
        <div>暂无待审批的SOP</div>
    </div>
</div>

<!-- 审批操作模态框 -->
<div class="modal-overlay" id="approval-modal">
    <div class="modal">
        <div class="modal-header">
            <div class="modal-title" id="modal-title">审批操作</div>
            <div class="modal-close" onclick="closeModal()">✕</div>
        </div>
        <div class="modal-body">
            <div id="modal-content">
                <div style="margin-bottom: 1rem;">
                    <label style="display: block; font-size: 0.875rem; color: var(--text-secondary); margin-bottom: 0.5rem;">
                        审批意见
                    </label>
                    <textarea class="comment-input" id="approval-comment" 
                              placeholder="请输入审批意见..."></textarea>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="action-btn secondary" onclick="closeModal()">取消</button>
            <button class="action-btn success" id="confirm-btn" onclick="confirmAction()">
                确认
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
let currentTab = 'pending';
let currentSOPId = null;
let currentAction = null;

// 初始化
document.addEventListener('DOMContentLoaded', () => {
    loadApprovalList();
});

// 切换标签页
function switchTab(tab) {
    currentTab = tab;
    
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('active');
    });
    event.currentTarget.classList.add('active');
    
    loadApprovalList();
}

// 加载审批列表
async function loadApprovalList() {
    try {
        let status = '';
        if (currentTab === 'pending') {
            status = 'pending_review';
        } else if (currentTab === 'approved') {
            status = 'approved';
        }
        
        const response = await fetch(`/sop/api/list?status=${status}`);
        const result = await response.json();
        
        if (result.success) {
            displayApprovalList(result.data);
        }
    } catch (error) {
        console.error('加载失败:', error);
    }
}

// 显示审批列表
function displayApprovalList(sops) {
    const listEl = document.getElementById('approval-list');
    const emptyEl = document.getElementById('empty-state');
    
    if (sops.length === 0) {
        listEl.innerHTML = '';
        emptyEl.style.display = 'block';
        return;
    }
    
    emptyEl.style.display = 'none';
    
    listEl.innerHTML = sops.map(sop => `
        <div class="approval-item" data-sop-id="${sop.id}">
            <div class="approval-item-header">
                <div class="approval-item-info">
                    <div class="approval-item-title-row">
                        <span class="approval-item-file-number">${sop.file_number || '--'}</span>
                        <span class="approval-item-title">${sop.title}</span>
                    </div>
                    <div class="approval-item-meta">
                        <span>🏭 ${sop.product_name || '未知产品'}</span>
                        <span>👤 ${sop.creator || '--'}</span>
                        <span>📅 ${formatDate(sop.create_time)}</span>
                    </div>
                </div>
                <div class="approval-item-status">
                    <span class="status-badge ${sop.status}">${getStatusText(sop.status)}</span>
                    <span class="current-step">${getStepText(sop.current_step)}</span>
                </div>
            </div>
            <div class="approval-item-body">
                <!-- 审批流程 -->
                <div class="approval-flow">
                    ${renderApprovalFlow(sop.current_step)}
                </div>
                
                <!-- 操作按钮 -->
                ${currentTab === 'pending' ? `
                <div class="approval-actions">
                    <button class="action-btn primary" onclick="previewSOP(${sop.id})">
                        👁️ 预览
                    </button>
                    <button class="action-btn success" onclick="openApprovalModal(${sop.id}, 'approve')">
                        ✅ 通过
                    </button>
                    <button class="action-btn danger" onclick="openApprovalModal(${sop.id}, 'reject')">
                        ❌ 拒绝
                    </button>
                    <button class="action-btn secondary" onclick="openApprovalModal(${sop.id}, 'return')">
                        🔄 退回
                    </button>
                </div>
                ` : `
                <div class="approval-actions">
                    <button class="action-btn primary" onclick="previewSOP(${sop.id})">
                        👁️ 预览
                    </button>
                    <button class="action-btn secondary" onclick="downloadSOP(${sop.id})">
                        📥 下载
                    </button>
                </div>
                `}
            </div>
        </div>
    `).join('');
}

// 渲染审批流程
function renderApprovalFlow(currentStep) {
    const steps = [
        { key: 'creator_submit', label: '提交' },
        { key: 'number_review', label: '编号审核' },
        { key: 'department_review', label: '部门会签' },
        { key: 'quality_review', label: '质量审核' },
        { key: 'production_review', label: '生产审核' },
        { key: 'final_approval', label: '最终批准' },
        { key: 'completed', label: '完成' }
    ];
    
    const currentIndex = steps.findIndex(s => s.key === currentStep);
    
    return steps.map((step, index) => {
        let className = '';
        if (index < currentIndex) {
            className = 'completed';
        } else if (index === currentIndex) {
            className = 'current';
        }
        
        const html = `
            <div class="flow-step ${className}">
                <div class="flow-step-icon">
                    ${index < currentIndex ? '✓' : index + 1}
                </div>
                <div class="flow-step-label">${step.label}</div>
            </div>
        `;
        
        if (index < steps.length - 1) {
            return html + `
                <div class="flow-connector ${index < currentIndex ? 'completed' : ''}"></div>
            `;
        }
        return html;
    }).join('');
}

// 打开审批模态框
function openApprovalModal(sopId, action) {
    currentSOPId = sopId;
    currentAction = action;
    
    const modalTitle = document.getElementById('modal-title');
    const confirmBtn = document.getElementById('confirm-btn');
    
    if (action === 'approve') {
        modalTitle.textContent = '审批通过';
        confirmBtn.textContent = '✅ 确认通过';
        confirmBtn.className = 'action-btn success';
    } else if (action === 'reject') {
        modalTitle.textContent = '审批拒绝';
        confirmBtn.textContent = '❌ 确认拒绝';
        confirmBtn.className = 'action-btn danger';
    } else {
        modalTitle.textContent = '退回修改';
        confirmBtn.textContent = '🔄 确认退回';
        confirmBtn.className = 'action-btn secondary';
    }
    
    document.getElementById('approval-comment').value = '';
    document.getElementById('approval-modal').classList.add('active');
}

// 关闭模态框
function closeModal() {
    document.getElementById('approval-modal').classList.remove('active');
}

// 确认操作
async function confirmAction() {
    const comment = document.getElementById('approval-comment').value.trim();
    
    try {
        const response = await fetch(`/sop/api/review/${currentSOPId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                action: currentAction,
                reviewer: '当前用户', // 实际应从会话获取
                comments: comment
            })
        });
        
        const result = await response.json();
        
        if (result.success) {
            closeModal();
            loadApprovalList();
            alert(result.message);
        } else {
            alert(result.error || '操作失败');
        }
    } catch (error) {
        console.error('操作失败:', error);
        alert('操作失败，请重试');
    }
}

// 预览SOP
function previewSOP(id) {
    window.open(`/sop/preview/${id}`, '_blank');
}

// 下载SOP
function downloadSOP(id) {
    window.location.href = `/sop/api/download/${id}`;
}

// 辅助函数
function getStatusText(status) {
    const statusMap = {
        'draft': '草稿',
        'pending_review': '待审核',
        'approved': '已批准',
        'rejected': '已拒绝',
        'recycled': '已回收'
    };
    return statusMap[status] || status;
}

function getStepText(step) {
    const stepMap = {
        'creator_submit': '创建者提交',
        'number_review': '编号审核中',
        'department_review': '部门会签中',
        'quality_review': '质量审核中',
        'production_review': '生产审核中',
        'final_approval': '待最终批准',
        'completed': '已完成'
    };
    return stepMap[step] || step;
}

function formatDate(dateStr) {
    if (!dateStr) return '--';
    return new Date(dateStr).toLocaleDateString('zh-CN');
}
</script>
{% endblock %}