# qrmes-web-core runtime environment example
# Copy to runtime.env on the target server and fill real values there.
# Do not commit real webhook tokens or secrets.

MESAPP_HOST=0.0.0.0
MESAPP_PORT=8899
PYTHONPATH=/volume2/mes_ubuntu_split_result/qrmes-web-core/app_web:/volume2/mes_ubuntu_split_result/qrmes-web-core:/volume2/mes_ubuntu_split_result/qrmes-web-core/../qrmes-motor-qc/app_web:/volume2/mes_ubuntu_split_result/qrmes-web-core/../qrmes-finance-service/app_web

# DingTalk custom robot for tool expiry reminders.
# Create it in the target DingTalk group: Group settings -> Bot/Smart assistant -> Custom robot -> Security: Sign.
TOOL_EXPIRY_DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=REPLACE_WITH_ACCESS_TOKEN
TOOL_EXPIRY_DINGTALK_SECRET=SEC_REPLACE_WITH_SIGN_SECRET
