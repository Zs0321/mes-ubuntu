# ============================================================
# Odoo 环境变量配置模板
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 根据实际环境修改下面的配置值
# 3. 敏感信息（密码、密钥等）务必妥善保管
# ============================================================

# ------------------------------------------------------------
# PostgreSQL 数据库配置
# ------------------------------------------------------------
POSTGRES_DB=odoo
POSTGRES_USER=odoo
POSTGRES_PASSWORD=请修改为强密码
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ------------------------------------------------------------
# Odoo 基础配置
# ------------------------------------------------------------
# Odoo Web 端口
ODOO_PORT=8069

# Odoo Long Polling 端口（用于实时通信）
ODOO_LONGPOLLING_PORT=8072

# Odoo 主密码（用于数据库管理）
ODOO_MASTER_PASSWORD=请修改为强密码

# ------------------------------------------------------------
# Odoo 性能配置
# ------------------------------------------------------------
# 工作进程数（建议：CPU 核心数 * 2 + 1）
ODOO_WORKERS=4

# 最大定时任务线程数
ODOO_MAX_CRON_THREADS=2

# 内存限制（软限制，字节）
ODOO_LIMIT_MEMORY_SOFT=2147483648

# 内存限制（硬限制，字节）
ODOO_LIMIT_MEMORY_HARD=2684354560

# CPU 时间限制（秒）
ODOO_LIMIT_TIME_CPU=600

# 实际时间限制（秒）
ODOO_LIMIT_TIME_REAL=1200

# ------------------------------------------------------------
# pgAdmin 配置（可选）
# ------------------------------------------------------------
# pgAdmin 访问端口
PGADMIN_PORT=5050

# pgAdmin 登录邮箱
PGADMIN_EMAIL=admin@example.com

# pgAdmin 登录密码
PGADMIN_PASSWORD=admin

# ------------------------------------------------------------
# 其他配置
# ------------------------------------------------------------
# 时区
TZ=Asia/Shanghai

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info
