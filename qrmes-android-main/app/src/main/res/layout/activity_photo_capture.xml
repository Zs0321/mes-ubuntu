<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- 顶部工具栏 -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        style="@style/Widget.QRTestScanner.Toolbar"
        app:title="产品拍照"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <!-- 产品信息 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@color/md_infoContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="产品序列号："
                android:textSize="14sp"
                android:textColor="?attr/colorPrimary" />

            <TextView
                android:id="@+id/tvProductSerial"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textSize="14sp"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvProjectInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvProductTypeInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvOperatorInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvProcessInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- 相机预览 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fitCenter" />

        <com.testcenter.qrscanner.CameraGuideOverlayView
            android:id="@+id/cameraGuideOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/tvCameraGuideHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="16dp"
            android:background="#73000000"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:text="请将工件主体放入参考框内（辅助构图，不裁剪全幅上传）"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <!-- 拍照按钮覆盖层 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="#80000000">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCapture"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center_horizontal"
                app:icon="@drawable/ic_camera"
                app:iconSize="40dp"
                app:iconGravity="textStart"
                app:cornerRadius="40dp"
                style="@style/Widget.MaterialComponents.Button" />

        </LinearLayout>

    </FrameLayout>

    <!-- 底部操作按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="?attr/colorSurface">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectPhotos"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="选择照片"
            android:textSize="16sp"
            app:icon="@drawable/ic_photo_library"
            app:iconSize="24dp"
            app:iconGravity="textStart"
            app:cornerRadius="8dp"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpload"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="上传照片"
            android:textSize="16sp"
            app:icon="@drawable/ic_upload"
            app:iconSize="24dp"
            app:iconGravity="textStart"
            app:cornerRadius="8dp"
            android:layout_marginStart="8dp"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>

    <!-- 已选照片列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewPhotos"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/md_surfaceContainerLow" />

</LinearLayout>
