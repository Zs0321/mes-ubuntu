<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/md_fieldPressed" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="@color/md_primary" />
            <padding android:left="12dp" android:top="8dp" android:right="12dp" android:bottom="8dp" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/md_fieldPressed" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="@color/md_primary" />
            <padding android:left="12dp" android:top="8dp" android:right="12dp" android:bottom="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/md_fieldSurface" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="@color/md_outlineVariant" />
            <padding android:left="12dp" android:top="8dp" android:right="12dp" android:bottom="8dp" />
        </shape>
    </item>
</selector>
