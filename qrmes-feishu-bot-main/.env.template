# =========================
# qrmes-feishu-bot .env 模板
# =========================
# 复制为 .env 后按实际值修改。
# 若暂时不使用 OpenAI-compatible，可保留 FEISHU_BOT_LLM_* 为空，
# 当前默认优先走本机 Hermes API 做追问/总结/兜底。

# 基础服务
FEISHU_BOT_MODE=callback
FEISHU_BOT_HOST=0.0.0.0
FEISHU_BOT_PORT=8898
FEISHU_BOT_LOG_LEVEL=INFO

# 飞书应用
FEISHU_BOT_APP_ID=cli_xxxxxxxxxxxxxxxxx
FEISHU_BOT_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BOT_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxx
FEISHU_BOT_ENCRYPT_KEY=
FEISHU_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxxx
FEISHU_BOT_NAME=MES助手

# OpenAI-compatible（可选，作为回退）
FEISHU_BOT_LLM_BASE_URL=
FEISHU_BOT_LLM_API_KEY=
FEISHU_BOT_LLM_MODEL=gpt-5.4
FEISHU_BOT_LLM_TIMEOUT=20

# 工作目录
FEISHU_BOT_WORKSPACE_ROOT=/Volumes/172.16.30.10/volume2/mes_ubuntu_split_result
FEISHU_BOT_RESOURCE_CACHE_DIR=/Volumes/172.16.30.10/volume2/mes_ubuntu_split_result/qrmes-feishu-bot/runtime_cache

# Hermes / Web3Hermes
FEISHU_BOT_HERMES_BASE_URL=http://127.0.0.1:8787
FEISHU_BOT_HERMES_WORKSPACE=/Volumes/172.16.30.10/volume2/mes_ubuntu_split_result
